@charset "utf-8";

#bnr { cursor: pointer; font-family: Arial; }

div { display: inline-block; vertical-align: top; }

#bnr { font-size: 0px; user-select: none; -webkit-tap-highlight-color: tran=
sparent; touch-action: manipulation; }

#bnr.isSetup .overflowHidden { overflow: hidden; }

a { display: inline-block; vertical-align: top; text-decoration: none; }

.zContainer { position: relative; }

@keyframes glow-out {=20
  0% { transform: translate(-50%, -50%); }
  30%, 60% { transform: translate(-50%, -50%) scale(7); }
  100% { transform: translate(-50%, -50%) scale(7); opacity: 0; }
